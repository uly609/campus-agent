CAMPUSFLOW_ENV=local
CAMPUSFLOW_DEMO_TOKEN=demo-token
CAMPUSFLOW_PROVIDER_ENCRYPTION_SECRET=replace-with-a-long-random-local-secret
CAMPUSFLOW_API_RATE_LIMIT=120
CAMPUSFLOW_CHAT_RATE_LIMIT=20
DATABASE_URL=postgresql+psycopg://campusflow:campusflow@postgres:5432/campusflow
REDIS_URL=redis://redis:6379/0
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=campusflow-password
OPENAI_API_KEY=
LOCAL_PRIMARY_API_KEY=
LOCAL_BACKUP_API_KEY=
LOCAL_PRIMARY_CHAT_URL=
LOCAL_BACKUP_CHAT_URL=
CLOUD_FALLBACK_CHAT_URL=
LOCAL_PRIMARY_CHAT_MODEL=qwen2.5:7b
LOCAL_BACKUP_CHAT_MODEL=qwen2.5:3b
CLOUD_FALLBACK_CHAT_MODEL=qwen-plus
LOCAL_PRIMARY_EMBEDDING_URL=
LOCAL_BACKUP_EMBEDDING_URL=
CLOUD_FALLBACK_EMBEDDING_URL=
LOCAL_PRIMARY_EMBEDDING_MODEL=bge-m3
LOCAL_BACKUP_EMBEDDING_MODEL=bge-m3
CLOUD_FALLBACK_EMBEDDING_MODEL=text-embedding-v3
LOCAL_PRIMARY_VLM_URL=
LOCAL_BACKUP_VLM_URL=
CLOUD_FALLBACK_VLM_URL=
LOCAL_PRIMARY_VLM_MODEL=qwen2.5-vl:7b
LOCAL_BACKUP_VLM_MODEL=qwen2.5-vl:3b
CLOUD_FALLBACK_VLM_MODEL=qwen-vl-plus
VLM_API_KEY=
PROVIDER_TIMEOUT_SECONDS=8
PROVIDER_MAX_RETRIES=2
MEMORY_ENABLED=true
